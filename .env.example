# Microsoft Foundry project endpoint
AZURE_AI_PROJECT_ENDPOINT=https://your-resource.services.ai.azure.com/api/projects/your-project

# Microsoft Foundry API key
AZURE_AI_API_KEY=your-api-key-here

# Model deployment name
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-4o

# Agent 365 App Registration (created in Setup step 3)
A365_CLIENT_ID=your-app-client-id
A365_CLIENT_SECRET=your-client-secret
A365_TENANT_ID=your-tenant-id

# Only needed for setup_a365.py
A365_SP_ID=your-agent365-sp-object-id
A365_APP_OBJ_ID=your-app-object-id
